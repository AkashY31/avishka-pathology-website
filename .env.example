# ── Azure OpenAI (REQUIRED for AI chat) ─────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Azure Speech (OPTIONAL — voice uses browser Web Speech API by default) ──
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus

# ── Database ─────────────────────────────────────────────────────────────────
# Production (Railway volume mounted at /data):
DATABASE_URL=sqlite:////data/avishka_pathology.db

# ── Admin Dashboard ───────────────────────────────────────────────────────────
# Access: https://your-app.railway.app/admin/bookings?token=YOUR_TOKEN
ADMIN_TOKEN=change-this-to-a-strong-password
